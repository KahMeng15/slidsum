# SlidSum Configuration Template
# Copy this file to .env and fill in your values.

# Directories (relative to project root or absolute)
INPUT_DIR="./input_slides"
OUTPUT_DIR="./output_files"
PROMPTS_DIR="./prompts"

# Timeout before application auto-quits while idle (in seconds, 0 = disabled)
IDLE_TIMEOUT=300

# Slide file patterns (comma separated)
FILE_PATTERN="*.pdf,*.pptx,*.ppt,*.png,*.jpg,*.jpeg"

# Max image dimension sent to AI vision API (pixels). Larger pages are auto-resized.
MAX_IMAGE_DIM=1600

# OpenAI API Key (for OpenAI provider)
OPENAI_API_KEY="your_openai_api_key_here"

# Google Gemini API Key (for Gemini provider)
GEMINI_API_KEY="your_gemini_api_key_here"

# Gemini models (comma separated, first = primary, rest = fallbacks)
# Examples: gemini-2.0-flash, gemini-1.5-pro, gemma-4-31b-it
GEMINI_MODELS="gemini-2.0-flash"

# OpenAI models (comma separated, first = primary, rest = fallbacks)
# For image-heavy slides, gpt-4o is recommended. gpt-4o-mini for text-only.
OPENAI_MODELS="gpt-4o-mini"

# AI Provider to use for slide analysis (openai or gemini)
SUMMARIZER_PROVIDER="gemini"
